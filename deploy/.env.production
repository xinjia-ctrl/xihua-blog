# ==========================================
# 溪花博客 - 生产环境变量
# ==========================================
# 复制此文件为 .env 并修改其中的值
# 部署时需在服务器上设置这些环境变量

# JWT 密钥（至少 32 个字符，生产环境必须修改）
JWT_SECRET=your_jwt_secret_key_at_least_32_chars_here

# MySQL 数据库配置
MYSQL_PASSWORD=your_mysql_password_here

# 部署域名
DOMAIN=your-domain.com
